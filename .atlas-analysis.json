  "keyFeatures": [
    "4-step checkout flow: product selection → payment form → order summary → result",
    "Secure card tokenization directly with Wompi (card data never sent to backend)",
    "Real-time transaction status polling (up to 12 attempts at 2.5s intervals)",
    "Clean Architecture backend with NestJS, TypeORM, and PostgreSQL",
    "React 19 SPA with Redux Toolkit state management and checkout progress persistence",
    "Automatic product seeding on startup with 3 demo products",
    "125 backend unit tests with ~99% code coverage",
    "Swagger/OpenAPI documentation at /api/docs",
    "Integrity hash validation using SHA-256 for Wompi transactions"
  ],
  "publicApiSurface": [
    "GET /api/products",
    "GET /api/products/:id",
    "GET /api/payments/acceptance-token",
    "POST /api/transactions",
    "GET /api/transactions/:id",
    "GET /api/transactions/:id/status",
    "GET /api/deliveries/transaction/:transactionId"
  ]
